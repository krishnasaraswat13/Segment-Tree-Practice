//creation

class Main{
    public static void main(String[] args) {
        int arr[] = {1, 3, 5, 7, 9, 11};
        int n = arr.length;
        int st[] = new int[4 * n];  //the size is 4*n because in worst case the segment tree can have 4*n nodes as 
        buildSTMax(arr, st, 0, n - 1, 0);
        for (int i = 0; i < st.length; i++) {
            System.out.print(st[i] + " ");
        }
    }

    public static void buildSTMax(int arr[], int st[], int ss, int se, int si) {
        if (ss == se) {
            st[si] = arr[ss];
            return;
        }
        int mid = (ss + se) / 2;
        buildSTMax(arr, st, ss, mid, si * 2 + 1);
        buildSTMax(arr, st, mid + 1, se, si * 2 + 2);
        st[si] = Math.max(st[si * 2 + 1], st[si * 2 + 2]);
    }
}

//query
public static int getMax(int st[], int ss, int se, int qs, int qe, int si) {
    if (qs > se || qe < ss) {
        return Integer.MIN_VALUE; // No overlap //-infinity so that we compare with max and it will not affect the result and other will be chosen

    }
    if (qs <= ss && qe >= se) {
        return st[si]; // Total overlap
    } //partial overlap
    int mid = (ss + se) / 2;
    return Math.max(getMax(st, ss, mid, qs, qe, 2 * si + 1),
                    getMax(st, mid + 1, se, qs, qe, 2 * si + 2));

}   

//update
public static void updateMax(int st[], int ss, int se, int index, int value, int si) {
    if (index < ss || index > se) {
        return; // Out of bounds
    }
    if (ss == se) {
        st[si] = value; // Update leaf node
        return;
    }
    int mid = (ss + se) / 2;
    updateMax(st, ss, mid, index, value, 2 * si + 1);
    updateMax(st, mid + 1, se, index, value, 2 * si + 2);
    st[si] = Math.max(st[2 * si + 1], st[2 * si + 2]); // Update internal node
}