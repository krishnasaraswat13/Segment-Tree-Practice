//in this we have to return the frequency of the second largest element in a given range //and we can change the value of any element in the array
// for this we will build a segment tree where each node will store the largest and second largest element in that segment
//to answer the query we will combine the results of the left and right child nodes to find the largest and second largest element in the range
class Main{
    public static void main(String[] args) {
        int arr[] = {1, 3, 5, 7, 9, 11};
        int n = arr.length;
        Node st[] = new Node[4 * n];  //the size is 4*n because in worst case the segment tree can have 4*n nodes as 
        buildST(arr, st, 0, n - 1, 0);
        System.out.println(query(st, 0, n - 1, 1, 4, 0).secondMax); //query for the range [1,4]
        update(st, 0, n - 1, 2, 10, 0); //update index 2 to value 10
        System.out.println(query(st, 0, n - 1, 1, 4, 0).secondMax); //query for the range [1,4] after update
        
    }

    public static void buildST(int arr[], Node st[], int ss, int se, int si) {
        if (ss == se) {
            st[si] = new Node(arr[ss], Integer.MIN_VALUE); //leaf node
            return;
        }
        int mid = (ss + se) / 2;
        buildST(arr, st, ss, mid, si * 2 + 1);
        buildST(arr, st, mid + 1, se, si * 2 + 2);
        st[si] = merge(st[si * 2 + 1], st[si * 2 + 2]);
    }

    public static Node merge(Node leftNode, Node rightNode) {
       ArrayList<Integer> list = new ArrayList<>();
         list.add(leftNode.max);
        list.add(leftNode.secondMax);
        list.add(rightNode.max);
        list.add(rightNode.secondMax);
        Collections.sort(list, Collections.reverseOrder());
        int max = list.get(0);
        int secondMax = Integer.MIN_VALUE;
        for (int i = 1; i < list.size(); i++) {
            if (list.get(i) != max) {
                secondMax = list.get(i);
                break;
            }
        }
        return new Node(max, secondMax);


    }
    public static class Node {
        int max;
        int secondMax;
        public Node(int max, int secondMax) {
            this.max = max;
            this.secondMax = secondMax;
        }
    }
    public static int query(Node st[], int ss, int se, int qs, int qe, int si) {
        if (qs > se || qe < ss) {
            return Integer.MIN_VALUE; // No overlap
        }
        if (qs <= ss && qe >= se) {
            return st[si].secondMax; // Total overlap
        }
        int mid = (ss + se) / 2;
        Node leftNode = query(st, ss, mid, qs, qe, 2 * si + 1);
        Node rightNode = query(st, mid + 1, se, qs, qe, 2 * si + 2);
        Node mergedNode = merge(leftNode, rightNode);
        return mergedNode;
    }
    public static void update(Node st[], int ss, int se, int index, int value, int si) {
        if (index < ss || index > se) {
            return; // Out of bounds
        }
        if (ss == se) {
            st[si] = new Node(value, Integer.MIN_VALUE); // Update leaf node
            return;
        }
        int mid = (ss + se) / 2;
        update(st, ss, mid, index, value, 2 * si + 1);
        update(st, mid + 1, se, index, value, 2 * si + 2);
        st[si] = merge(st[2 * si + 1], st[2 * si + 2]); // Update internal node
    }

}