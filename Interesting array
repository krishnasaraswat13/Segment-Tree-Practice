// The logic follows these steps:

// Bitwise Construction: Use a difference array for each of the 30 bits to mark which indices must have that bit set.

// Build Array: If a bit's prefix sum at index i is >0, set that bit in A[i].

// Verification: Build a Segment Tree over A to calculate range AND and ensure every constraint (L,R,Q) is actually satisfied.


import java.util.Scanner;
import java.io.PrintWriter;

public class Main {
    static int[] A;
    static int[] tree;

    // Segment Tree to verify Range AND
    static void build(int node, int start, int end) {
        if (start == end) {
            tree[node] = A[start];
            return;
        }
        int mid = (start + end) / 2;
        build(2 * node, start, mid);
        build(2 * node + 1, mid + 1, end);
        tree[node] = tree[2 * node] & tree[2 * node + 1];
    }

    static int query(int node, int start, int end, int l, int r) {
        if (r < start || end < l) return (1 << 30) - 1; // All 1s is identity for AND
        if (l <= start && end <= r) return tree[node];
        int mid = (start + end) / 2;
        return query(2 * node, start, mid, l, r) & query(2 * node + 1, mid + 1, end, l, r);
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        PrintWriter out = new PrintWriter(System.out);

        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();
        int m = sc.nextInt();

        int[][] constraints = new int[m][3];
        int[][] diff = new int[30][n + 2];

        for (int i = 0; i < m; i++) {
            int l = sc.nextInt();
            int r = sc.nextInt();
            int q = sc.nextInt();
            constraints[i][0] = l;
            constraints[i][1] = r;
            constraints[i][2] = q;

            // Difference Array: Mark bits that MUST be 1
            for (int k = 0; k < 30; k++) {
                if (((q >> k) & 1) == 1) {
                    diff[k][l]++;
                    diff[k][r + 1]--;
                }
            }
        }

        A = new int[n + 1];
        for (int k = 0; k < 30; k++) {
            int count = 0;
            for (int i = 1; i <= n; i++) {
                count += diff[k][i];
                if (count > 0) {
                    A[i] |= (1 << k); // Set the k-th bit  //this step is same as doing power of 2 and adding to the ans but here we are directly setting the bit in the array index which is more efficient than calculating power of 2 and adding to the ans
                }
            }
        }

        // Verification Step
        tree = new int[4 * n + 1];
        build(1, 1, n);

        boolean possible = true;
        for (int i = 0; i < m; i++) {
            if (query(1, 1, n, constraints[i][0], constraints[i][1]) != constraints[i][2]) {
                possible = false;
                break;
            }
        }

        if (possible) {
            out.println("YES");
            for (int i = 1; i <= n; i++) {
                out.print(A[i] + (i == n ? "" : " "));
            }
            out.println();
        } else {
            out.println("NO");
        }

        out.flush(); // Crucial to actually print the buffered text
        sc.close();
    }
}