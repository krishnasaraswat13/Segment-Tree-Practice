import java.util.*;

class Solution {
    public List<Integer> fallingSquares(int[][] positions) {
        int n = positions.length;
        int[] heights = new int[n];
        
        for (int i = 0; i < n; i++) {
            int left = positions[i][0];
            int size = positions[i][1];
            int right = left + size;
            heights[i] += size;
            
            // Check all previous squares for overlap
            for (int j = 0; j < i; j++) {
                int pLeft = positions[j][0];
                int pSize = positions[j][1];
                int pRight = pLeft + pSize;
                
                // Standard interval overlap check: [L1, R1) and [L2, R2)
                if (left < pRight && right > pLeft) {
                    heights[i] = Math.max(heights[i], heights[j] + size);
                }
            }
        }
        
        // Transform into "running maximum" as required by the problem
        List<Integer> ans = new ArrayList<>();
        int curMax = 0;
        for (int h : heights) {
            curMax = Math.max(curMax, h);
            ans.add(curMax);
        }
        return ans;
    }
}

